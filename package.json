{
  "name": "bookmark-extension",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "backup:now": "bash tools/backup-project.sh",
    "check:file-size": "node tools/check-file-size.mjs",
    "report:file-size": "node tools/check-file-size.mjs --report",
    "audit:split": "node tools/split-audit.mjs",
    "audit:split:json": "node tools/split-audit.mjs --json > docs/split-audit.json",
    "audit:imports": "node tools/check-relative-imports.mjs",
    "deps:circular": "npx --yes madge --extensions js --circular src",
    "deps:orphans": "npx --yes dependency-cruiser src --config tools/dependency-cruiser.cjs --output-type err-long"
  },
